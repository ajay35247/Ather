# See repo root .env.example for the canonical list. This file is a minimal
# overlay specifically for running `pnpm --filter @ather/api dev` standalone.

NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000
TRUST_PROXY=1

# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ather-dev-secret-change-in-production

# Auth M1 — see docs/deployment/vercel-railway.md
GOOGLE_CLIENT_ID=
MFA_ISSUER=Ather
# Never set to true in production; leaks OTPs / reset tokens in the response.
OTP_RETURN_CODE=false

# Datastores — only needed once you wire DB-backed stores.
DATABASE_URL=postgresql://ather:ather@localhost:5432/ather_db
REDIS_URL=redis://localhost:6379

