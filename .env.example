# ─────────────────────────────────────────────────────────────────────────────
# Ather — root .env.example
#
# This file aggregates the environment variables used across the monorepo so
# new contributors have a single starting point. Per-service overrides still
# live in `services/<name>/.env.example` and `apps/<name>/.env.example`.
#
# Copy to `.env` (this file is gitignored via `.gitignore`) and fill in real
# values for any service you intend to run locally:
#
#   cp .env.example .env
#
# Phase 0 services run with in-memory stores; DATABASE_URL / REDIS_URL are only
# required from Phase 1 onward (when `npm run infra:up` is also needed).
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── apps/web (Next.js) ───────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── apps/api (Core Loop API: identity → feed → messaging → AI → notifs) ─────
API_PORT=4000
CLIENT_URL=http://localhost:3000
# REQUIRED in production. A weak default is used in development only; the API
# refuses to boot in production without a strong secret (see middleware/auth).
JWT_SECRET=ather-dev-secret-change-in-production

# ── services/auth ────────────────────────────────────────────────────────────
AUTH_PORT=4001
JWT_ACCESS_SECRET=dev-only-change-me-access
JWT_REFRESH_SECRET=dev-only-change-me-refresh
JWT_ACCESS_TTL_SECONDS=300
JWT_REFRESH_TTL_SECONDS=2592000

# ── services/profile ─────────────────────────────────────────────────────────
PROFILE_PORT=4002
# JWT_ACCESS_SECRET (above) is shared so profile can verify tokens issued by auth

# ── Datastores (Phase 1+; provided by `npm run infra:up`) ────────────────────
DATABASE_URL=postgres://ather:ather@localhost:5432/ather
REDIS_URL=redis://localhost:6379

# ── Optional integrations (Phase 3+) ─────────────────────────────────────────
# Real payment providers are NOT wired in Phase 0–2. Wallet/top-up endpoints
# are explicitly demo-only until these are configured AND NODE_ENV !== 'production'.
# STRIPE_SECRET_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
