# ─────────────────────────────────────────────────────────────────────────────
# Ather — root .env.example
#
# This file aggregates the environment variables used across the monorepo so
# new contributors have a single starting point. Per-service overrides still
# live in `services/<name>/.env.example` and `apps/<name>/.env.example`.
#
# Copy to `.env` (this file is gitignored via `.gitignore`) and fill in real
# values for any service you intend to run locally:
#
#   cp .env.example .env
#
# Phase 0 services run with in-memory stores; DATABASE_URL / REDIS_URL are only
# required from Phase 1 onward (when `npm run infra:up` is also needed).
#
# For production deployment, see `docs/DEPLOYMENT.md`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── apps/web (Next.js — deployed to Vercel) ──────────────────────────────────
WEB_PORT=3000
# Public URL of the API. In production this is the Railway-issued URL for the
# api service, e.g. https://ather-api-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── apps/api (deployed to Railway) ───────────────────────────────────────────
# Port Railway injects via the PORT env var; we fall back to 4000 for local.
API_PORT=4000
PORT=4000
# Origin allowed by CORS / Socket.IO. In production set to the Vercel URL.
CLIENT_URL=http://localhost:3000
# REQUIRED in production. A weak default is used in development only; the API
# refuses to boot in production without a strong secret (see middleware/auth).
# Generate with: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=ather-dev-secret-change-in-production
# How many proxy hops to trust (1 = behind a single LB like Railway / Vercel).
TRUST_PROXY=1

# ── Auth M1 ──────────────────────────────────────────────────────────────────
# Required for Google OAuth in production. The /api/auth/google endpoint will
# refuse to verify tokens without this in NODE_ENV=production.
GOOGLE_CLIENT_ID=
# Issuer name shown in the user's authenticator app for TOTP 2FA.
MFA_ISSUER=Ather
# If true, /api/auth/otp/request and /password/forgot return the code/token
# in the response. Default: only in non-production. Never set this to true
# in production — it bypasses the email delivery channel entirely.
OTP_RETURN_CODE=false

# ── services/auth ────────────────────────────────────────────────────────────
AUTH_PORT=4001
JWT_ACCESS_SECRET=dev-only-change-me-access
JWT_REFRESH_SECRET=dev-only-change-me-refresh
JWT_ACCESS_TTL_SECONDS=300
JWT_REFRESH_TTL_SECONDS=2592000

# ── services/profile ─────────────────────────────────────────────────────────
PROFILE_PORT=4002
# JWT_ACCESS_SECRET (above) is shared so profile can verify tokens issued by auth

# ── Datastores (Phase 1+; provided by `npm run infra:up`) ────────────────────
# Railway provisions DATABASE_URL automatically when you attach a Postgres
# plugin to the api service.
DATABASE_URL=postgres://ather:ather@localhost:5432/ather
REDIS_URL=redis://localhost:6379

# ── Optional integrations (Phase 3+) ─────────────────────────────────────────
# Real payment providers are NOT wired in Phase 0–2. Wallet/top-up endpoints
# are explicitly demo-only until these are configured AND NODE_ENV !== 'production'.
# STRIPE_SECRET_KEY=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

