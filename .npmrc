# Compatibility with existing hoisted-dependency expectations from the
# previous npm-workspaces setup. Allows transitive deps to be resolvable
# from any workspace without requiring every package.json to be exhaustive.
shamefully-hoist=true

# Avoid network drift between developers and CI.
strict-peer-dependencies=false
auto-install-peers=true

# pnpm v10 changed `pnpm deploy` to require `inject-workspace-packages=true`
# by default, which breaks our service Dockerfiles that run
# `pnpm --filter <svc> deploy --prod`. Restore the v9 behaviour so the
# command continues to produce a self-contained prod bundle.
force-legacy-deploy=true

