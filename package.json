{
  "name": "ather",
  "version": "0.1.0",
  "private": true,
  "description": "Ather — Omni-Social Operating System monorepo (apps + services + packages)",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/api\"",
    "dev:web": "npm --workspace @ather/web run dev",
    "dev:api": "npm --workspace=apps/api run dev",
    "dev:auth": "npm --workspace @ather/auth-service run dev",
    "dev:profile": "npm --workspace @ather/profile-service run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "5.4.5"
  }
}
